# .env.example
# Example environment variables for local development
# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak realm import file (mounted in the container)
KEYCLOAK_REALM_FILE=realm-export.json

# Backend settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend settings
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# Database (will be added in Phase 2)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=issuesdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MCP server settings (Phase 3) - host/port the mcp/ FastMCP server listens on
MCP_HOST=0.0.0.0
MCP_PORT=9000

# MCP client settings (Phase 4.3) - URL the backend agent uses to reach the mcp/ server;
# FastMCP's http transport serves the MCP endpoint at /mcp, not /, so the path suffix is required
MCP_SERVER_URL=http://mcp:9000/mcp

# OpenAI API Key (Phase 4.2) - get your own key from https://platform.openai.com/api-keys, put the real value in .env only
OPENAI_API_KEY=sk-your-key-here

# Per-agent model overrides - optional, these match docker-compose.yml's own
# defaults, so only uncomment/change a line if you want a different model
# for that specific agent. GUARDRAIL_MODEL (the prompt-injection/off-topic
# classifier, Phase 5.1) also exists with the same nano default but isn't
# listed here since it's rarely worth overriding on its own.
MAIN_AGENT_MODEL=openai:gpt-5.4-mini
CUSTOMER_PROFILE_AGENT_MODEL=openai:gpt-5.4-nano
SUMMARIZE_AGENT_MODEL=openai:gpt-5.4-nano

# Redis short-term conversation memory (Phase 4.10) - checkpointer backing the
# main agent's per-thread conversation state; requires Redis 8+ (bundles
# RedisJSON/RediSearch modules the checkpointer needs)
REDIS_HOST=redis
REDIS_PORT=6379

# LangSmith observability - get your own key from https://smith.langchain.com/settings,
# put the real value in .env only. LANGSMITH_ENDPOINT must match the region your
# LangSmith org/workspace lives in (e.g. https://eu.api.smith.langchain.com for EU orgs,
# https://api.smith.langchain.com for US) or auth will fail.
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_your-key-here
LANGSMITH_PROJECT=acme-agent

